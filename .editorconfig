# EditorConfig helps maintain consistent coding styles.
# https://editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

# Markdown
[*.md]
trim_trailing_whitespace = false

# YAML
[*.{yml,yaml}]
indent_size = 2

# JSON
[*.json]
indent_size = 2

# TypeScript / JavaScript / React
[*.{ts,tsx,js,jsx,mjs,cjs}]
indent_size = 2

# CSS
[*.{css,scss,sass}]
indent_size = 2

# HTML
[*.html]
indent_size = 2

# Java
[*.java]
indent_size = 4

# XML (Spring, Maven, etc.)
[*.{xml}]
indent_size = 2

# Properties files
[*.properties]
indent_size = 2

# Shell scripts
[*.sh]
indent_style = space
indent_size = 2

# Docker
[Dockerfile]
indent_style = space
indent_size = 2

# Makefile
[Makefile]
indent_style = tab
